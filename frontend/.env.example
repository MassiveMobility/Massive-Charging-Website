# Public env values are bundled into browser code and must never contain secrets.
NEXT_PUBLIC_SITE_URL=https://www.massivecharging.com
NEXT_PUBLIC_SITE_NAME=Massive Charging
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=replace-with-public-google-maps-key

# Server-only env values must not use the NEXT_PUBLIC_ prefix.
CMS_API_BASE_URL=https://cms.example.com
CMS_API_TOKEN=replace-with-a-secure-token
STATIONS_API_BASE_URL=https://backend.1charging.com
STATIONS_API_BEARER_TOKEN=replace-with-stations-api-token
STATIONS_API_X_API=replace-with-stations-x-api-key
